{
  "schemaVersion": "0.3.0",
  "project": {
    "projectId": "cut2kit-wall-layout-example",
    "jobName": "Cut2Kit Wall Layout Example",
    "customer": "Example Customer",
    "site": "example-site",
    "description": "AI-first workflow for dimensioned elevation PDF to framing and OSB sheathing PDFs.",
    "units": "imperial"
  },
  "ai": {
    "enabled": true,
    "agentName": "Cut2Kit Agent",
    "provider": "codex",
    "model": "gpt-5.4",
    "reasoningEffort": "xhigh",
    "preferFastServiceTierWhenAvailable": true,
    "primaryWorkflow": "ai-first-wall-layout",
    "runtimeGenerationOrder": [
      "extract_wall_geometry",
      "generate_framing_layout",
      "generate_sheathing_layout",
      "validate_and_render"
    ],
    "promptReferencePaths": {
      "reusableSummaryPdf": ".docs/reusable_prompt_summary_framing_osb.pdf",
      "framingSystemPrompt": ".docs/system-framing.md",
      "framingInitialPrompt": ".docs/user-framing.md",
      "sheathingSystemPrompt": ".docs/system-sheathing.md",
      "sheathingInitialPrompt": ".docs/user-sheathing.md",
      "validationChecklist": ".docs/validation-checklist.md"
    },
    "allowedTasks": [
      "interpret_elevation_pdf",
      "generate_framing_layout",
      "generate_sheathing_layout",
      "validate_results",
      "render_pdfs"
    ]
  },
  "discovery": {
    "searchRecursively": true,
    "preferredFolders": [".docs", "examples", "elevations", "references"],
    "knownSettingsFileNames": ["cut2kit.settings.json"]
  },
  "input": {
    "dimensionPriority": "explicit_first",
    "ambiguityPolicy": {
      "onMissingOrConflictingDimensions": "ask_for_confirmation_and_stop"
    },
    "scope": {
      "supportedWallTypes": ["single_wall"],
      "supportedUnitModes": ["single_unit"],
      "supportedOpeningShapes": ["rectangular"],
      "plannedFutureSupport": [
        "non_rectangular_openings",
        "varying_head_heights",
        "sloped_tops",
        "gables"
      ]
    },
    "elevationIntake": {
      "geometrySourcePriority": ["dimension_text", "drawn_geometry"],
      "horizontalDimensionMode": "cumulative_from_left_edge",
      "units": "inch"
    }
  },
  "artifacts": {
    "saveExtractedGeometryJson": true,
    "saveFramingLayoutJson": true,
    "saveSheathingLayoutJson": true,
    "saveValidationReportJson": true,
    "paths": {
      "extractedGeometry": "output/artifacts/extracted-elevation.json",
      "framingLayout": "output/artifacts/framing-layout.json",
      "sheathingLayout": "output/artifacts/sheathing-layout.json",
      "validationReport": "output/artifacts/validation-report.json"
    }
  },
  "framing": {
    "enabled": true,
    "material": {
      "label": "SPF",
      "nominalSize": "2x6",
      "thicknessIn": 1.5,
      "depthIn": 5.5
    },
    "plates": {
      "top": {
        "enabled": true,
        "continuity": "continuous",
        "orientationInElevation": "flat"
      },
      "bottom": {
        "enabled": true,
        "continuity": "continuous",
        "orientationInElevation": "flat"
      }
    },
    "endStuds": {
      "leftCount": 2,
      "rightCount": 2
    },
    "openingSideStuds": {
      "enabled": true,
      "countPerSide": 1,
      "leftOffsetMode": "shift_left",
      "leftOffsetIn": 1.5,
      "rightOffsetIn": 0.0,
      "preserveClearOpenings": true
    },
    "studLayout": {
      "enabled": true,
      "spacingMode": "on_center",
      "spacingIn": 16.0,
      "originSide": "left",
      "direction": "left_to_right",
      "gridRestartAfterOpening": false,
      "stopBeforeNextBearingStudWithinOrEqualIn": 16.0
    },
    "openings": {
      "clearArchitecturalOpenings": true,
      "headMember": {
        "windows": true,
        "doors": true
      },
      "sillMember": {
        "windows": true,
        "doors": false
      }
    },
    "crippleStuds": {
      "aboveHeads": true,
      "belowWindowSills": true,
      "splitGridStudsInsideOpenings": true,
      "allowStudsThroughOpenings": false
    },
    "labeling": {
      "includeMemberSchedule": true,
      "includeStudCenterSchedule": true
    }
  },
  "sheathing": {
    "enabled": true,
    "materialLabel": "7/16 in OSB",
    "panelThicknessIn": 0.4375,
    "sheet": {
      "nominalWidthIn": 48.0,
      "nominalHeightIn": 96.0,
      "installedOrientation": "vertical",
      "runDirection": "left_to_right",
      "allowTerminalRip": true
    },
    "layoutGoal": "installation_layout",
    "openingsRemainUncovered": true,
    "output": {
      "includeOverallLayoutPage": true,
      "includePerSheetCutoutPages": true,
      "includeFasteningPage": false
    },
    "notes": {
      "includeDisclaimer": true,
      "panelEdgeGapIn": 0.125,
      "supportedEdgeBehavior": "edges_over_framing_or_blocking"
    }
  },
  "fastening": {
    "enabled": false,
    "typicalReferenceOnly": true,
    "edgeSpacingIn": 6.0,
    "fieldSpacingIn": 12.0,
    "edgeDistanceIn": 0.375,
    "includeOverdrivingWarning": true,
    "disclaimerText": "Confirm final fastening schedule, blocking, and edge support requirements with the governing code, engineering, and the panel manufacturer.",
    "noteLines": [
      "Use the stud framing layout for support lines.",
      "Place panel edges over framing members or provide blocking where required.",
      "Keep fasteners approximately 3/8 in back from panel edges and do not overdrive fasteners."
    ]
  },
  "prompts": {
    "framingSystemPath": ".docs/system-framing.md",
    "framingUserPath": ".docs/user-framing.md",
    "sheathingSystemPath": ".docs/system-sheathing.md",
    "sheathingUserPath": ".docs/user-sheathing.md",
    "validationChecklistPath": ".docs/validation-checklist.md"
  },
  "rendering": {
    "units": "inch",
    "dimensionFormat": "feet-and-inches",
    "framing": {
      "pageSize": "letter",
      "pageOrientation": "landscape",
      "includeMemberSchedule": true,
      "titleTemplate": "{source} - Stud Framing Layout",
      "subtitleTemplate": "{material} framing. Plates shown flat."
    },
    "sheathing": {
      "pageSize": "letter",
      "pageOrientation": "landscape",
      "scaleToFitFirstPage": true,
      "cutoutDetailsPerPage": 4,
      "titleTemplate": "{source} - OSB Sheathing Layout",
      "subtitleTemplate": "{material}, nominal {sheet} sheets. Openings remain uncovered.",
      "fasteningTitleTemplate": "{source} - Fastening Pattern and Panel Edge Notes"
    }
  },
  "output": {
    "root": "output",
    "artifactsDir": "output/artifacts",
    "reportsDir": "output/reports",
    "pdfDir": "output/pdfs",
    "overwritePolicy": "overwrite"
  }
}